{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Average Sentiment (Hourly)",
      "type": "timeseries",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, AVG(sentiment) AS avg_sentiment FROM posts WHERE analyzed_at IS NOT NULL AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -1,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#73BF69" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#F2495C", "value": -1.0 },
              { "color": "#FF9830", "value": -0.3 },
              { "color": "#FADE2A", "value": -0.1 },
              { "color": "#73BF69", "value": 0.1 },
              { "color": "#56A64B", "value": 0.5 }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "thresholdsStyle": { "mode": "area" },
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "Sentiment Distribution",
      "type": "histogram",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT sentiment FROM posts WHERE analyzed_at IS NOT NULL AND $__timeFilter(created_at);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#8AB8FF" }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": 0.25,
        "fillOpacity": 70,
        "gradientMode": "scheme",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "Issue Tag Distribution",
      "type": "piechart",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 9 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FILTER (WHERE tag = 'bug') AS bug, COUNT(*) FILTER (WHERE tag = 'server') AS server, COUNT(*) FILTER (WHERE tag = 'cheat') AS cheat, COUNT(*) FILTER (WHERE tag = 'performance') AS performance, COUNT(*) FILTER (WHERE tag = 'matchmaking') AS matchmaking, COUNT(*) FILTER (WHERE tag = 'update') AS \"update\", COUNT(*) FILTER (WHERE tag = 'praise') AS praise FROM posts, unnest(issue_tags) AS tag WHERE analyzed_at IS NOT NULL AND $__timeFilter(created_at);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
    },
    {
      "title": "Positive Posts",
      "type": "stat",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 9 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS positive FROM posts WHERE analyzed_at IS NOT NULL AND sentiment > 0.1 AND $__timeFilter(created_at);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#73BF69" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#73BF69", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "title": "Negative Posts",
      "type": "stat",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 13 },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS negative FROM posts WHERE analyzed_at IS NOT NULL AND sentiment < -0.1 AND $__timeFilter(created_at);",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#F2495C" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#F2495C", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "title": "Recent Reviews",
      "type": "table",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgresql" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "rawSql": "SELECT source, LEFT(content, 200) AS content, sentiment, array_to_string(issue_tags, ', ') AS tags, created_at AS time FROM posts WHERE analyzed_at IS NOT NULL ORDER BY created_at DESC LIMIT 30;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "sentiment" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#F2495C", "value": null },
                    { "color": "#FF9830", "value": -0.3 },
                    { "color": "#FADE2A", "value": -0.1 },
                    { "color": "#73BF69", "value": 0.1 },
                    { "color": "#56A64B", "value": 0.5 }
                  ]
                }
              },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "content" },
            "properties": [
              { "id": "custom.width", "value": 400 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "tags" },
            "properties": [
              { "id": "custom.width", "value": 140 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "source" },
            "properties": [
              { "id": "custom.width", "value": 70 }
            ]
          }
        ]
      }
    },
    {
      "title": "Sentiment Analysis — Requests/sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "rate(sentiment_analysis_total[5m])",
          "legendFormat": "requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#8AB8FF" }
        },
        "overrides": []
      }
    },
    {
      "title": "Sentiment Analysis — Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(sentiment_analysis_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(sentiment_analysis_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(sentiment_analysis_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sentinelops", "pubg", "community"],
  "templating": { "list": [] },
  "time": { "from": "now-3d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "SentinelOps — Community Monitoring",
  "uid": "sentinelops-main",
  "version": 4
}
