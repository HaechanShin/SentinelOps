# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx

# Steam
STEAM_API_KEY=your_steam_api_key
STEAM_APP_ID=578080

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sentinelops:sentinelops@postgres:5432/sentinelops
DATABASE_URL_SYNC=postgresql://sentinelops:sentinelops@postgres:5432/sentinelops
POSTGRES_USER=sentinelops
POSTGRES_PASSWORD=sentinelops
POSTGRES_DB=sentinelops

# Redis
REDIS_URL=redis://redis:6379/0

# Slack
SLACK_BOT_TOKEN=xoxb-xxxx
SLACK_SIGNING_SECRET=xxxx
SLACK_APP_TOKEN=xapp-xxxx
SLACK_ALERT_CHANNEL=#community-alerts

# Internal
INTERNAL_API_URL=http://app:8000

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=sentinelops

# API Security
API_SECRET_KEY=your_api_secret_key

# App
LOG_LEVEL=INFO
POLLING_INTERVAL_SECONDS=3600
SENTIMENT_DROP_THRESHOLD=0.3
SPIKE_MULTIPLIER=2.0
ROLLING_WINDOW_MINUTES=60
