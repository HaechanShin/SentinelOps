# AI provider
# anthropic keeps Claude native tool_use for context gathering.
# ollama uses a local Ollama model with JSON tool planning.
# openai uses an OpenAI-compatible /chat/completions endpoint.
AI_PROVIDER=anthropic

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_RETRIES=3

# Local LLM / Qwen
# For Docker Desktop with Ollama running on the host, keep host.docker.internal.
# For running the app directly on your machine, use http://localhost:11434.
LOCAL_LLM_BACKEND=ollama
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_MODEL=qwen3.6:latest
LOCAL_LLM_TEMPERATURE=0.2
LOCAL_LLM_CONTEXT_TOKENS=16384
LOCAL_LLM_TOP_P=0.9
LOCAL_LLM_TOP_K=20
LOCAL_LLM_MIN_P=0.0
LOCAL_LLM_REPEAT_PENALTY=1.05
LOCAL_LLM_PRESENCE_PENALTY=0.0
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_MAX_RETRIES=3
LOCAL_LLM_KEEP_ALIVE=10m
LOCAL_LLM_THINK=false

# Steam — change STEAM_APP_ID to monitor a different Steam title.
# Find an app ID at https://steamdb.info/ or in the game's Steam store URL.
STEAM_API_KEY=your_steam_api_key
STEAM_APP_ID=578080

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sentinelops:sentinelops@postgres:5432/sentinelops
DATABASE_URL_SYNC=postgresql://sentinelops:sentinelops@postgres:5432/sentinelops
POSTGRES_USER=sentinelops
POSTGRES_PASSWORD=sentinelops
POSTGRES_DB=sentinelops

# Redis
REDIS_URL=redis://redis:6379/0

# Slack
SLACK_BOT_TOKEN=xoxb-xxxx
SLACK_SIGNING_SECRET=xxxx
SLACK_APP_TOKEN=xapp-xxxx
SLACK_ALERT_CHANNEL=#community-alerts

# Internal
INTERNAL_API_URL=http://app:8000

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=sentinelops

# API Security
API_SECRET_KEY=your_api_secret_key

# App
LOG_LEVEL=INFO
# Hourly: collect Steam reviews + patch notes, then run sentiment analysis.
POLLING_INTERVAL_SECONDS=3600
# Daily alert detection compares the most recent N hours to the prior N hours.
# Defaults match a "yesterday vs the day before" cadence.
SENTIMENT_DROP_THRESHOLD=0.2
SPIKE_MULTIPLIER=2.0
ALERT_WINDOW_HOURS=24
ALERT_MIN_SAMPLE_SIZE=20
ALERT_COOLDOWN_HOURS=24
# Hour of the UTC day to run the daily alert pipeline. 0 = UTC 00:00 (= KST 09:00).
DAILY_ALERT_HOUR_UTC=0
